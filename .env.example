# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Chat + embeddings (OPENAI_EMBED_DIMENSIONS must match your Pinecone index)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-large
OPENAI_EMBED_DIMENSIONS=3072

# On 429 / quota: wait for API hint or backoff, then retry (chat + embeddings)
OPENAI_MAX_RETRIES=8
OPENAI_RETRY_CAP_SECONDS=120

# Pinecone — serverless index: dimension = OPENAI_EMBED_DIMENSIONS (3072 here), metric cosine
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
# Optional placement for scripts/create_pinecone_index.py (defaults: aws / us-east-1)
# PINECONE_SERVERLESS_CLOUD=aws
# PINECONE_SERVERLESS_REGION=us-east-1

# All portfolio chunks share this namespace; vectors carry project_id in metadata
PINECONE_NAMESPACE=portfolio

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval defaults
RAG_K=8
RAG_FETCH_K_MAX=48
RAG_MMR_LAMBDA=0.55

# CORS — comma-separated origins for the Next.js dev server
CORS_ORIGINS=http://localhost:3000

# Optional: MongoDB for cover letter history (sidebar). If unset, history is stored in data/cover_letter_history.json
# Local MongoDB (default port): mongodb://127.0.0.1:27017/portfolio_cover_letter
# MONGODB_URI=mongodb://127.0.0.1:27017/portfolio_cover_letter
# Atlas: MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=portfolio
# MONGODB_DB_NAME=portfolio_cover_letter
# MONGODB_COLLECTION_COVER_LETTERS=cover_letter_history
